# PatternWise Backend Environment Variables
# Copy this file to .env and update values as needed

# Application Environment
NODE_ENV=development
# Valid values: development, production, test

# Server Configuration
PORT=5000
HOST=localhost

# CORS Configuration
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000

# LeetCode API Configuration
LEETCODE_API_URL=https://leetcode.com/graphql
# Timeout for LeetCode API requests in milliseconds (100-30000)
LEETCODE_TIMEOUT_MS=5000

# Logging Configuration
LOG_LEVEL=info
# Valid values: error, warn, info, debug, trace

# Feature Flags
# Enable response schema validation (development only, default: true)
ENABLE_RESPONSE_VALIDATION=true
# Enable request/response logging (default: true)
ENABLE_REQUEST_LOGGING=true

# Rate Limiting (optional)
# Enable rate limiting on API endpoints (default: false)
RATE_LIMIT_ENABLED=false
# Rate limit window in milliseconds (default: 900000 = 15 minutes)
RATE_LIMIT_WINDOW_MS=900000
# Maximum requests per window per IP (default: 100)
RATE_LIMIT_MAX_REQUESTS=100
